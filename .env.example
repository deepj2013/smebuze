# Copy to .env and set values. Used by API and docker-compose.production.yml
JWT_SECRET=change-me-use-openssl-rand-base64-32
DB_PASSWORD=change-me-secure-postgres-password

# Database name (API default is smebuze). If you created the DB with another name (e.g. smebuzz), set it here:
# DB_NAME=smebuzz
DB_NAME=smebuze
